# Provider selection: anthropic | openai | gemini | grok | openrouter | ollama
LLM_PROVIDER=anthropic
LLM_MODEL=

# API keys — only the key matching LLM_PROVIDER is required
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
GROK_API_KEY=xai-...
OPENROUTER_API_KEY=sk-or-...

# Ollama (only when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1

# RAG
TARGET_REPO_PATH=/path/to/your/target/repo
CHROMA_PERSIST_DIR=/path/to/your/target/repo/.chroma

# GitHub PR integration
GITHUB_TOKEN=ghp_...
GITHUB_REPO=username/repo-name
